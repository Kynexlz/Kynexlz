-- Toggles
local toggles = {}
local toggleStates = {
    Pushup = false,
    Situp = false,
    Meditate = false,
    BenchPress = false,
    Treadmill = false,
    Pullups = false
}

local function createToggle(name, color)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, -10, 0, 55)
    toggleFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    toggleFrame.Parent = scrollFrame
    local tc = Instance.new("UICorner", toggleFrame)
    tc.CornerRadius = UDim.new(0, 10)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "🔥 Auto " .. name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 80, 0, 35)
    toggleBtn.Position = UDim2.new(1, -90, 0.5, -17.5)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    toggleBtn.Text = "OFF"
    toggleBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggleBtn.TextScaled = true
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.Parent = toggleFrame
    local btnCorner = Instance.new("UICorner", toggleBtn)
    btnCorner.CornerRadius = UDim.new(0, 8)

    toggles[name] = {frame = toggleFrame, btn = toggleBtn, state = false}

    toggleBtn.MouseButton1Click:Connect(function()
        toggleStates[name] = not toggleStates[name]
        toggles[name].state = toggleStates[name]
        
        if toggleStates[name] then
            toggleBtn.BackgroundColor3 = color
            toggleBtn.Text = "ON"
            toggleBtn.TextColor3 = Color3.new(1,1,1)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            toggleBtn.Text = "OFF"
            toggleBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
    end)
end

-- Create all toggles
