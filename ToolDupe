local function getHeldTool()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return v
        end
    end
    return nil
end

local function stackTool(amount)
    local tool = getHeldTool()
    if not tool then
        Status.Text = "❌ Equip a tool first!"
        task.wait(2)
        Status.Text = "Hold a tool and click the button"
        return
    end

    Status.Text = "🔄 Stacking " .. tool.Name .. " x" .. amount .. "..."

    for i = 1, amount do
        local clone = tool:Clone()
        clone.Parent = player.Backpack
        
        task.wait(0.12)  -- Slow delay = lower detection chance

        if i % 8 == 0 then
            task.wait(0.4)  -- Extra pause every few stacks
        end
    end

    Status.Text = "✅ Finished stacking " .. amount .. " " .. tool.Name
    task.wait(3)
    Status.Text = "Hold a tool and click the button"
end

DupeButton.MouseButton1Click:Connect(function()
    local num = tonumber(AmountBox.Text)
    if not num or num < 1 then
        Status.Text = "❌ Enter a valid number!"
        task.wait(2)
        Status.Text = "Hold a tool and click the button"
        return
    end
    
    -- Cap it reasonably to avoid instant flags
    if num > 500 then
        num = 500
        AmountBox.Text = "500"
    end

    stackTool(num)
end)

