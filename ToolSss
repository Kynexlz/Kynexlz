-- ✅ SILENT REAL DUPE ATTEMPT v2 for Islands (easy.gg) - April 2026
-- Works on DELTA, XENO, SYNAPSE X (pure Lua - no custom functions)
-- Non-visual, no GUI, no prints unless error
-- Chat command: /amount <number> while HOLDING the tool (in hand or backpack)
-- Tries client + forced replication tricks to make it persist on drop/rejoin

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

local PREFIX = "/amount "

local function getHeldTool()
    local char = player.Character
    if char then
        for _, obj in ipairs(char:GetChildren()) do
            if obj:IsA("Tool") then return obj end
        end
    end
    
    -- Backpack fallback
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, obj in ipairs(backpack:GetChildren()) do
            if obj:IsA("Tool") then return obj end
        end
    end
    return nil
end

local function forceReplicate(tool, value)
    if not tool then return end
    
    local amountValue = tool:FindFirstChild("Amount")
    if not amountValue or not amountValue:IsA("IntValue") then
        amountValue = tool:FindFirstChild("Amount", true) -- deep search
    end
    
    if amountValue and amountValue:IsA("IntValue") then
        amountValue.Value = value
        
        -- Force replication tricks (these sometimes bypass client-only desync)
        local originalParent = tool.Parent
        
        -- 1. Brief unparent + reparent (triggers server replication in many games)
        tool.Parent = nil
        task.wait(0.03)
        tool.Parent = originalParent
        
        -- 2. Extra force (sometimes needed for Islands stackables)
        if originalParent then
            tool.Parent = workspace
            task.wait(0.03)
            tool.Parent = originalParent
        end
        
        -- 3. Fire common Islands drop/save remotes if they exist (silent attempt)
        pcall(function()
            local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage:FindFirstChild("Events")
            if remotesFolder then
                local dropRemote = remotesFolder:FindFirstChild("Drop") or remotesFolder:FindFirstChild("DropTool") or remotesFolder:FindFirstChild("Place") 
                if dropRemote and dropRemote:IsA("RemoteEvent") then
                    dropRemote:FireServer(tool, value) -- try to tell server the new amount
                end
            end
        end)
        
        -- 4. Final client-side lock + heartbeat set (keeps value if server tries to revert)
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if amountValue and amountValue.Parent then
                amountValue.Value = value
            else
                connection:Disconnect()
            end
        end)
        
        -- Auto-clean after 5 seconds
        task.delay(5, function()
            if connection then connection:Disconnect() end
        end)
    end
end

player.Chatted:Connect(function(message)
    if not message:lower():sub(1, #PREFIX) == PREFIX:lower() then return end
    
    local valueStr = message:sub(#PREFIX + 1):match("^%s*(.-)%s*$")
    local value = tonumber(valueStr)
    
    if not value or value < 1 then return end -- silent invalid
    
    local tool = getHeldTool()
    if not tool then return end
    
    forceReplicate(tool, value)
    
    -- Extra safety: re-apply on any tool change
    task.delay(0.1, function()
        local newTool = getHeldTool()
        if newTool and newTool == tool then
            forceReplicate(newTool, value)
        end
    end)
end)

-- Auto re-apply on character respawn (island travel / death)
player.CharacterAdded:Connect(function(char)
    task.wait(1) -- wait for tools to load
    local tool = getHeldTool()
    if tool then
        -- Re-apply last known? (can't store globally easily, so user re-types command)
    end
end)

print("✅ Islands Silent Real-Dupe v2 loaded | /amount <number> while holding tool")
print("   Drop / place / rejoin immediately after for best chance of saving")
