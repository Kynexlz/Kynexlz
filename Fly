local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
local root = char:WaitForChild("HumanoidRootPart")

--// VARIABLES
local flying = false
local flySpeed = 50
local bodyGyro, bodyVel
local animationTrack

--// GUI
local screenGui = Instance.new("ScreenGui", game.CoreGui)
screenGui.Name = "FlyGui"

local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 250, 0, 180)
frame.Position = UDim2.new(0.05, 0, 0.3, 0)
frame.BackgroundColor3 = Color3.fromRGB(15,15,15)
frame.Active = true
frame.Draggable = true

Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)

-- TITLE
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,40)
title.Text = "FLY SYSTEM"
title.TextColor3 = Color3.fromRGB(255,255,255)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.TextScaled = true

-- FLY BUTTON
local flyBtn = Instance.new("TextButton", frame)
flyBtn.Size = UDim2.new(0.8,0,0,35)
flyBtn.Position = UDim2.new(0.1,0,0.3,0)
flyBtn.Text = "TOGGLE FLY"
flyBtn.BackgroundColor3 = Color3.fromRGB(25,25,25)
flyBtn.TextColor3 = Color3.new(1,1,1)
flyBtn.Font = Enum.Font.GothamBold
flyBtn.TextScaled = true
Instance.new("UICorner", flyBtn)

-- SPEED SLIDER
local speedLabel = Instance.new("TextLabel", frame)
speedLabel.Size = UDim2.new(1,0,0,25)
speedLabel.Position = UDim2.new(0,0,0.55,0)
speedLabel.Text = "Speed: 50"
speedLabel.TextColor3 = Color3.new(1,1,1)
speedLabel.BackgroundTransparency = 1
speedLabel.Font = Enum.Font.Gotham
speedLabel.TextScaled = true

local slider = Instance.new("TextButton", frame)
slider.Size = UDim2.new(0.8,0,0,20)
slider.Position = UDim2.new(0.1,0,0.7,0)
slider.Text = ""
slider.BackgroundColor3 = Color3.fromRGB(40,40,40)
Instance.new("UICorner", slider)

-- MOBILE CONTROL BUTTONS
local upBtn = Instance.new("TextButton", frame)
upBtn.Size = UDim2.new(0.35,0,0,30)
upBtn.Position = UDim2.new(0.1,0,0.85,0)
upBtn.Text = "UP"
upBtn.BackgroundColor3 = Color3.fromRGB(25,25,25)
upBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", upBtn)

local downBtn = Instance.new("TextButton", frame)
downBtn.Size = UDim2.new(0.35,0,0,30)
downBtn.Position = UDim2.new(0.55,0,0.85,0)
downBtn.Text = "DOWN"
downBtn.BackgroundColor3 = Color3.fromRGB(25,25,25)
downBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", downBtn)

--// ANIMATION
local anim = Instance.new("Animation")
anim.AnimationId = "rbxassetid://113298527970213"

--// FUNCTIONS
local function startFly()
	if flying then return end
	flying = true
	
	bodyGyro = Instance.new("BodyGyro", root)
	bodyGyro.P = 9e4
	bodyGyro.maxTorque = Vector3.new(9e9,9e9,9e9)
	bodyGyro.cframe = root.CFrame

	bodyVel = Instance.new("BodyVelocity", root)
	bodyVel.velocity = Vector3.new(0,0,0)
	bodyVel.maxForce = Vector3.new(9e9,9e9,9e9)

	-- Animation
	animationTrack = hum:LoadAnimation(anim)
	animationTrack:Play()

	-- INVINCIBLE FEEL
	hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
	hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)

	RunService.RenderStepped:Connect(function()
		if flying then
			local cam = workspace.CurrentCamera
			local moveDir = hum.MoveDirection
			
			bodyVel.velocity = (cam.CFrame.LookVector * moveDir.Z + cam.CFrame.RightVector * moveDir.X) * flySpeed
			bodyGyro.cframe = cam.CFrame
		end
	end)
end

local function stopFly()
	flying = false
	
	if bodyGyro then bodyGyro:Destroy() end
	if bodyVel then bodyVel:Destroy() end
	if animationTrack then animationTrack:Stop() end

	hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
	hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
end

--// BUTTONS
flyBtn.MouseButton1Click:Connect(function()
	if flying then
		stopFly()
	else
		startFly()
	end
end)

-- SPEED SLIDER (simple tap = increase)
slider.MouseButton1Click:Connect(function()
	flySpeed = flySpeed + 20
	if flySpeed > 200 then flySpeed = 20 end
	speedLabel.Text = "Speed: "..flySpeed
end)

-- MOBILE UP/DOWN
local up = false
local down = false

upBtn.MouseButton1Down:Connect(function() up = true end)
upBtn.MouseButton1Up:Connect(function() up = false end)

downBtn.MouseButton1Down:Connect(function() down = true end)
downBtn.MouseButton1Up:Connect(function() down = false end)

RunService.RenderStepped:Connect(function()
	if flying and bodyVel then
		if up then
			bodyVel.velocity = bodyVel.velocity + Vector3.new(0, flySpeed, 0)
		elseif down then
			bodyVel.velocity = bodyVel.velocity - Vector3.new(0, flySpeed, 0)
		end
	end
end)
