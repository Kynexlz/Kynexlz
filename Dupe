-- Get Tools Folder
local toolsFolder = ReplicatedStorage:FindFirstChild("Tools")

local toolButtons = {}

local function createToolButton(tool)
	if not tool:IsA("Tool") then return end

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 48)
	btn.BackgroundColor3 = Color3.fromRGB(48, 48, 55)
	btn.Text = "  " .. tool.Name
	btn.TextColor3 = Color3.new(1,1,1)
	btn.TextXAlignment = Enum.TextXAlignment.Left
	btn.TextSize = 16
	btn.Font = Enum.Font.Gotham
	btn.Parent = scroll

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 10)
	btnCorner.Parent = btn

	btn.MouseButton1Click:Connect(function()
		for _, b in pairs(toolButtons) do
			b.BackgroundColor3 = Color3.fromRGB(48, 48, 55)
		end
		btn.BackgroundColor3 = Color3.fromRGB(80, 140, 200)
		btn:SetAttribute("SelectedTool", tool)
	end)

	table.insert(toolButtons, btn)
end

-- Populate
if toolsFolder then
	for _, tool in pairs(toolsFolder:GetChildren()) do
		createToolButton(tool)
	end

	listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
