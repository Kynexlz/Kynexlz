--// SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

--// CREATE REMOTE IF NOT EXISTS
local remote = ReplicatedStorage:FindFirstChild("DupeRapier")
if not remote then
    remote = Instance.new("RemoteEvent")
    remote.Name = "DupeRapier"
    remote.Parent = ReplicatedStorage
end

--// CREATE SERVER SCRIPT (only runs once)
if not ReplicatedStorage:FindFirstChild("DupeRapier_Server") then
    local serverScript = Instance.new("Script")
    serverScript.Name = "DupeRapier_Server"
    serverScript.Parent = ReplicatedStorage
    
    serverScript.Source = [[
        local remote = game.ReplicatedStorage:WaitForChild("DupeRapier")

        remote.OnServerEvent:Connect(function(player, amount)
            local char = player.Character
            if not char then return end

            local tool = char:FindFirstChild("captainsRapier")
            if not tool or not tool:IsA("Tool") then return end

            amount = math.clamp(amount, 1, 50)

            local stack = tool:FindFirstChild("Amount")

            if stack and stack:IsA("IntValue") then
                stack.Value += amount
            else
                for i = 1, amount do
                    local clone = tool:Clone()
                    clone.Parent = player.Backpack
                end
            end
        end)
    ]]
end

