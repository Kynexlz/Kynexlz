	warning.TextColor3 = Color3.fromRGB(255, 100, 100)
	warning.TextScaled = true
	warning.Font = Enum.Font.GothamBold
	warning.Parent = mainFrame
	warning.ZIndex = 10
end

local toolButtons = {}

local function createToolButton(tool)
	if not tool:IsA("Tool") then return end
	
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 50)
	btn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
	btn.Text = tool.Name
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 16
	btn.TextXAlignment = Enum.TextXAlignment.Left
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 8)
	btnCorner.Parent = btn
	
	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, 15)
	padding.Parent = btn
	
	btn.Parent = scrollFrame
	
	btn.MouseButton1Click:Connect(function()
		-- Highlight selected
		for _, b in pairs(toolButtons) do
			b.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
		end
		btn.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
		
		-- Store selected tool
		btn:SetAttribute("SelectedTool", tool)
	end)
	
	table.insert(toolButtons, btn)
	return btn
end

-- Populate list
if toolsFolder then
	for _, tool in pairs(toolsFolder:GetChildren()) do
		createToolButton(tool)
	end
	
	-- Update canvas size
	listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 20)
	end)
end

-- Live Search
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	local query = searchBox.Text:lower()
	
	for _, btn in pairs(toolButtons) do
		if btn.Text:lower():find(query) then
			btn.Visible = true
		else
			btn.Visible = false
		end
	end
end)

-- Duplicate Function
dupeButton.MouseButton1Click:Connect(function()
	local qty = tonumber(qtyBox.Text)
	if not qty or qty < 1 then
		qty = 1
		qtyBox.Text = "1"
	end
	
	local selectedTool = nil
	for _, btn in pairs(toolButtons) do
		if btn.BackgroundColor3 == Color3.fromRGB(70, 130, 180) then
			selectedTool = btn:GetAttribute("SelectedTool")
			break
		end
	end
	
	if not selectedTool then
		-- Optional: show a toast "Select a tool first"
		return
	end
	
	local backpack = player:FindFirstChild("Backpack")
	if not backpack then return end
	
	for i = 1, qty do
		local clone = selectedTool:Clone()
		clone.Parent = backpack
	end
	
	-- Visual feedback
	local originalColor = dupeButton.BackgroundColor3
	dupeButton.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
	wait(0.2)
	dupeButton.BackgroundColor3 = originalColor
end)

-- Make draggable
local dragging = false
local dragInput
local dragStart
local startPos

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

mainFrame.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input == dragInput then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

print("Islands Visual Dupe GUI loaded! Search for tools in ReplicatedStorage.Tools and duplicate them.")
