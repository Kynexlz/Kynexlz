--// ALL IN ONE DUPE SYSTEM

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

-- Create RemoteEvent if it doesn't exist
local remote = ReplicatedStorage:FindFirstChild("DuplicateItem")
if not remote then
    remote = Instance.new("RemoteEvent")
    remote.Name = "DuplicateItem"
    remote.Parent = ReplicatedStorage
end

--// ================= GUI =================
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "DupeGUI"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 250, 0, 150)
frame.Position = UDim2.new(0.5, -125, 0.5, -75)
frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
frame.BorderSizePixel = 2

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Item Duplicator"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1

local box = Instance.new("TextBox", frame)
box.Size = UDim2.new(0.8,0,0,30)
box.Position = UDim2.new(0.1,0,0.4,0)
box.PlaceholderText = "Amount"
box.Text = ""
box.TextColor3 = Color3.new(1,1,1)
box.BackgroundColor3 = Color3.fromRGB(30,30,30)

local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(0.8,0,0,30)
button.Position = UDim2.new(0.1,0,0.7,0)
button.Text = "DUPLICATE"
button.TextColor3 = Color3.new(1,1,1)
button.BackgroundColor3 = Color3.fromRGB(40,40,40)

--// ================= CLIENT =================
button.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end

    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end

    local amount = tonumber(box.Text)
    if not amount or amount <= 0 then return end

    remote:FireServer(tool.Name, amount)
end)

--// ================= SERVER =================
if game:GetService("RunService"):IsServer() then

    remote.OnServerEvent:Connect(function(plr, toolName, amount)
        local char = plr.Character
        if not char then return end

        local tool = char:FindFirstChild(toolName)
        if not tool or not tool:IsA("Tool") then return end

        -- Anti abuse
        amount = math.clamp(amount, 1, 100)

        local stack = tool:FindFirstChild("Amount")

        if stack and stack:IsA("IntValue") then
            stack.Value += amount
        else
            for i = 1, amount do
                local clone = tool:Clone()
                clone.Parent = plr.Backpack
            end
        end
    end)

end
