local toolButtons = {}
local selectedToolName = nil

-- Populate list from ReplicatedStorage.Tools (common in dupe GUIs)
local toolsFolder = game.ReplicatedStorage:FindFirstChild("Tools")
if toolsFolder then
	for _, tool in pairs(toolsFolder:GetChildren()) do
		if tool:IsA("Tool") then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, 0, 0, 50)
			btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
			btn.Text = "   " .. tool.Name
			btn.TextColor3 = Color3.new(1,1,1)
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.TextSize = 16
			btn.Font = Enum.Font.Gotham
			btn.Parent = scroll

			local bc = Instance.new("UICorner")
			bc.CornerRadius = UDim.new(0, 10)
			bc.Parent = btn

			btn.MouseButton1Click:Connect(function()
				for _, b in pairs(toolButtons) do
					b.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
				end
				btn.BackgroundColor3 = Color3.fromRGB(70, 130, 200)
				selectedToolName = tool.Name
			end)

			table.insert(toolButtons, btn)
		end
	end

	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 30)
	end)
end

-- Live search
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	local query = searchBox.Text:lower()
	for _, btn in pairs(toolButtons) do
		btn.Visible = btn.Text:lower():find(query) ~= nil
	end
end)

-- Dupe Logic (best working method: modify held tool's Amount)
dupeBtn.MouseButton1Click:Connect(function()
	local amount = tonumber(amtBox.Text) or 1000000
	if amount < 1 then amount = 1000000 end

	local char = player.Character
	if not char then 
		status.Text = "No character found"
		return 
	end

	local heldTool = char:FindFirstChildWhichIsA("Tool")
	if not heldTool then
		status.Text = "Equip the tool you want to dupe first!"
		status.TextColor3 = Color3.fromRGB(255, 80, 80)
		return
	end

	-- Create or update Amount
	local amtVal = heldTool:FindFirstChild("Amount")
	if not amtVal then
		amtVal = Instance.new("IntValue")
		amtVal.Name = "Amount"
		amtVal.Parent = heldTool
	end
	amtVal.Value = amount

	status.Text = "Stack set to " .. amount .. " on " .. heldTool.Name
	status.TextColor3 = Color3.fromRGB(0, 255, 140)

	-- Flash button
	local origColor = dupeBtn.BackgroundColor3
	dupeBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 160)
	task.wait(0.25)
	dupeBtn.BackgroundColor3 = origColor
end)

-- Update status when equipping tool
local function updateHeld()
	local char = player.Character
	if char then
		local tool = char:FindFirstChildWhichIsA("Tool")
		if tool then
			status.Text = "Held: " .. tool.Name
			status.TextColor3 = Color3.fromRGB(255, 255, 255)
		else
			status.Text = "Equip a tool first..."
			status.TextColor3 = Color3.fromRGB(180, 180, 190)
		end
	end
end

player.Character.ChildAdded:Connect(updateHeld)
player.Character.ChildRemoved:Connect(updateHeld)
if player.Character then updateHeld() end

-- Draggable
local dragging = false
local dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

mainFrame.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

