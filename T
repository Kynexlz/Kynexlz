-- TOGGLE (Z)
local open = false

UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.Z then
		open = not open
		main.Visible = open
	end
end)

-- GET TOOL FUNCTION
local function getHeldTool()
	local char = player.Character
	if not char then return nil end

	for _, obj in ipairs(char:GetChildren()) do
		if obj:IsA("Tool") then
			return obj
		end
	end

	return nil
end

-- BUTTON LOGIC
button.MouseButton1Click:Connect(function()
	local tool = getHeldTool()

	if not tool then
		status.Text = "❌ No tool equipped"
		return
	end

	local amountValue = tool:FindFirstChild("Amount")

	if not amountValue or not amountValue:IsA("IntValue") then
		status.Text = "❌ Tool has no IntValue 'Amount'"
		return
	end

	local value = tonumber(input.Text)

	if not value then
		status.Text = "❌ Invalid number"
		return
	end

	amountValue.Value = value
	status.Text = "✔ Set tool amount to " .. value
end)
