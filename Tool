-- COOLDOWN + ACTION
local cooldown = false
local MAX = 1000
local COOLDOWN_TIME = 2

button.MouseButton1Click:Connect(function()
	if cooldown then
		addLog("⏳ Cooldown active (2s)")
		return
	end

	local tool = getTool()
	if not tool then
		addLog("❌ No tool equipped")
		return
	end

	local amount = tonumber(input.Text)
	if not amount then
		addLog("❌ Invalid number")
		return
	end

	if amount > MAX then
		addLog("⚠ Max is 1000")
		return
	end

	cooldown = true

	coins.Value += amount
	addLog("🪙 " .. tool.Name .. " gave +" .. amount .. " coins")

	task.delay(COOLDOWN_TIME, function()
		cooldown = false
	end)
end)
