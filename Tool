-- Function to get held tool
local function getHeldTool()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return v
        end
    end
    return nil
end

-- Main stack setter (best replication for Islands)
local function setStack(value)
    local tool = getHeldTool()
    if not tool then
        statusLabel.Text = "❌ Equip a tool first!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        task.delay(2, function() statusLabel.Text = "Ready" end)
        return
    end

    toolLabel.Text = "Tool: " .. tool.Name

    -- Find or create Amount
    local amount = tool:FindFirstChild("Amount")
    if not amount or not amount:IsA("IntValue") then
        if amount then amount:Destroy() end
        amount = Instance.new("IntValue")
        amount.Name = "Amount"
        amount.Parent = tool
    end

    -- Force the new stack size
    local oldValue = amount.Value
    amount.Value = value

    -- Islands-specific force replication (this is what makes it placeable)
    for i = 1, 6 do
        amount.Value = value
        task.wait(0.03)
        if i % 2 == 0 then
            amount.Value = value + 1
            task.wait(0.015)
            amount.Value = value
        end
    end

    -- Critical step: unequip + re-equip to force server sync
    pcall(function()
        tool.Parent = player.Backpack
        task.wait(0.1)
        player.Character.Humanoid:EquipTool(tool)
    end)

    -- Extra drop trick (often forces server to accept the stack)
    pcall(function()
        tool.Parent = workspace
        task.wait(0.15)
        tool.Parent = player.Backpack
        task.wait(0.1)
        player.Character.Humanoid:EquipTool(tool)
    end)

    statusLabel.Text = "✅ Stack set to " .. value .. " (should be placeable)"
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)

    print("Islands Stack Changer → " .. tool.Name .. " set to " .. value)
end

-- Button connections
applyBtn.MouseButton1Click:Connect(function()
    local input = amountBox.Text:lower():gsub("%s", "")
    local value = tonumber(input)

    if input == "inf" or input == "infinity" then
        value = 999999999
    end

    if not value or value < 1 then
        statusLabel.Text = "❌ Invalid number!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        task.delay(2, function() statusLabel.Text = "Ready" end)
        return
    end

    setStack(value)
end)

