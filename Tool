-- TOOL DETECTION (UNIVERSAL)
local function getTool()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChildOfClass("Tool")
end

-- UPDATE TOOL STATUS LIVE
game:GetService("RunService").RenderStepped:Connect(function()
	local tool = getTool()
	if tool then
		toolStatus.Text = "Tool: " .. tool.Name
	else
		toolStatus.Text = "Tool: None"
	end
end)

-- OPEN STATE
local open = false

local function openGui()
	main.Visible = true
	main:TweenSize(UDim2.new(0, 360, 0, 320), "Out", "Quint", 0.25, true)
end

local function closeGui()
	main:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Quint", 0.2, true)
	task.wait(0.2)
	main.Visible = false
end

-- KEY TOGGLE
UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.Z then
		open = not open
		if open then openGui() else closeGui() end
	end
end)

