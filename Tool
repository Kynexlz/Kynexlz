-- TOOL CHECK LOOP
task.spawn(function()
	while true do
		task.wait(0.3)
		character = player.Character or player.CharacterAdded:Wait()

		if hasToolEquipped() then
			toolStatus.Text = "Tool: Equipped"
			toolStatus.TextColor3 = Color3.fromRGB(0, 255, 170)
		else
			toolStatus.Text = "Tool: Not Equipped"
			toolStatus.TextColor3 = Color3.fromRGB(255, 200, 0)
		end
	end
end)

-- COOLDOWN + SETTINGS
local cooldown = false
local MAX_COINS = 1000
local COOLDOWN_TIME = 2

-- BUTTON ACTION
button.MouseButton1Click:Connect(function()
	if cooldown then
		addLog("⏳ Cooldown active (2s)")
		return
	end

	if not hasToolEquipped() then
		addLog("❌ You must hold a tool")
		return
	end

	local amount = tonumber(input.Text)

	if not amount then
		addLog("❌ Invalid number")
		return
	end

	if amount > MAX_COINS then
		addLog("⚠ Max allowed is 1000")
		return
	end

	cooldown = true

	coins.Value += amount
	addLog("🪙 Tool used → +" .. amount .. " coins")

	task.delay(COOLDOWN_TIME, function()
		cooldown = false
	end)
end)

-- Z TOGGLE
local open = false

local function openGui()
	main.Visible = true
	main:TweenSize(UDim2.new(0, 340, 0, 310), "Out", "Quint", 0.25, true)
end

local function closeGui()
	main:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Quint", 0.2, true)
	task.wait(0.2)
	main.Visible = false
end

UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.Z then
		open = not open
		if open then openGui() else closeGui() end
	end
end)

