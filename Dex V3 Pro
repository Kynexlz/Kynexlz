-- PROPERTIES
local function clearProps()
	for _,v in pairs(properties:GetChildren()) do
		if v:IsA("Frame") then v:Destroy() end
	end
end

local function addProperty(name, value, callback)
	local frame = Instance.new("Frame", properties)
	frame.Size = UDim2.new(1,-10,0,30)
	frame.BackgroundColor3 = Color3.fromRGB(30,30,40)
	Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)

	local box = Instance.new("TextBox", frame)
	box.Size = UDim2.new(1,0,1,0)
	box.Text = name .. ": " .. tostring(value)
	box.BackgroundTransparency = 1
	box.TextColor3 = Color3.new(1,1,1)

	box.FocusLost:Connect(function()
		local newVal = box.Text:split(": ")[2]
		callback(newVal)
	end)
end

local function showProps(obj)
	clearProps()

	addProperty("Name", obj.Name, function(v)
		obj.Name = v
	end)

	addProperty("Parent", obj.Parent and obj.Parent.Name or "nil", function()
	end)

	addProperty("Class", obj.ClassName, function()
	end)

	-- DELETE BUTTON
	local del = Instance.new("TextButton", properties)
	del.Size = UDim2.new(1,-10,0,30)
	del.Text = "Delete Instance"
	del.BackgroundColor3 = Color3.fromRGB(120,30,30)
	del.TextColor3 = Color3.new(1,1,1)

	del.MouseButton1Click:Connect(function()
		if obj then obj:Destroy() end
	end)
end

-- TREE SYSTEM
local function createItem(obj, indent, parentTable)
	parentTable = parentTable or explorer

	local container = Instance.new("Frame", parentTable)
	container.Size = UDim2.new(1,0,0,28)
	container.BackgroundTransparency = 1

	local button = Instance.new("TextButton", container)
	button.Size = UDim2.new(1,-10,1,0)
	button.Position = UDim2.new(0,10 * indent,0,0)
	button.Text = obj.Name
	button.BackgroundColor3 = Color3.fromRGB(28,28,38)
	button.TextColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", button).CornerRadius = UDim.new(0,8)

	local childrenFrame = Instance.new("Frame", container)
	childrenFrame.Size = UDim2.new(1,0,0,0)
	childrenFrame.Position = UDim2.new(0,0,1,0)
	childrenFrame.BackgroundTransparency = 1

	local layout = Instance.new("UIListLayout", childrenFrame)
	layout.Padding = UDim.new(0,4)

	local expanded = false

	button.MouseButton1Click:Connect(function()
		selectObject(obj)
		showProps(obj)

		expanded = not expanded
		childrenFrame:ClearAllChildren()

		if expanded then
			for _,child in pairs(obj:GetChildren()) do
				createItem(child, indent + 1, childrenFrame)
			end
		end
	end)
end

-- LOAD ROOT
for _,obj in pairs(game:GetChildren()) do
