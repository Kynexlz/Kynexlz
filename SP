--// SERVICES
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

--// KEY
local KEY = "Kynexlz"

--// GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "KynexHub"
gui.ResetOnSpawn = false

-- MOBILE SCALE
local scale = Instance.new("UIScale", gui)
scale.Scale = 1

--// UI FUNCTIONS
local function styleFrame(obj)
	obj.BackgroundColor3 = Color3.fromRGB(10,10,10)
	local stroke = Instance.new("UIStroke", obj)
	stroke.Color = Color3.fromRGB(255,255,255)
	stroke.Thickness = 1
	Instance.new("UICorner", obj).CornerRadius = UDim.new(0,10)
end

local function styleButton(btn)
	btn.BackgroundColor3 = Color3.fromRGB(15,15,15)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.AutoButtonColor = false
	
	local stroke = Instance.new("UIStroke", btn)
	stroke.Color = Color3.fromRGB(255,255,255)

	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)

	-- Hover animation
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {
			BackgroundColor3 = Color3.fromRGB(30,30,30)
		}):Play()
	end)

	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {
			BackgroundColor3 = Color3.fromRGB(15,15,15)
		}):Play()
	end)
end

local function styleBox(box)
	box.BackgroundColor3 = Color3.fromRGB(15,15,15)
	box.TextColor3 = Color3.new(1,1,1)
	box.PlaceholderColor3 = Color3.fromRGB(180,180,180)

	local stroke = Instance.new("UIStroke", box)
	stroke.Color = Color3.fromRGB(255,255,255)

	Instance.new("UICorner", box).CornerRadius = UDim.new(0,8)
end

--// TOGGLE BUTTON
local Toggle = Instance.new("TextButton", gui)
Toggle.Size = UDim2.new(0,50,0,50)
Toggle.Position = UDim2.new(1,-65,0.5,-25)
Toggle.Text = "≡"
styleButton(Toggle)
Toggle.Draggable = true

--// MAIN FRAME
local Main = Instance.new("Frame", gui)
Main.Size = UDim2.new(0,320,0,300)
Main.Position = UDim2.new(1,30,0.5,-150)
Main.Visible = false
Main.Active = true
Main.Draggable = true
styleFrame(Main)

local padding = Instance.new("UIPadding", Main)
padding.PaddingLeft = UDim.new(0,10)
padding.PaddingRight = UDim.new(0,10)
padding.PaddingTop = UDim.new(0,10)

local layout = Instance.new("UIListLayout", Main)
layout.Padding = UDim.new(0,8)

-- TITLE
local Title = Instance.new("TextLabel", Main)
Title.Text = "Kynex Hub"
Title.Size = UDim2.new(1,0,0,30)
Title.BackgroundTransparency = 1
Title.TextColor3 = Color3.new(1,1,1)
Title.TextScaled = true

-- INPUTS
local function makeBox(text)
	local box = Instance.new("TextBox", Main)
	box.Size = UDim2.new(1,0,0,35)
	box.PlaceholderText = text
	styleBox(box)
	return box
end

local WSBox = makeBox("WalkSpeed")
local JPBox = makeBox("JumpPower")

-- BUTTONS
local function makeButton(text)
	local btn = Instance.new("TextButton", Main)
	btn.Size = UDim2.new(1,0,0,35)
	btn.Text = text
	styleButton(btn)
	return btn
end

local WSBtn = makeButton("Apply WalkSpeed")
local JPBtn = makeButton("Apply JumpPower")
local InfBtn = makeButton("Infinite Jump: OFF")
local NoclipBtn = makeButton("Noclip: OFF")

--// KEY FRAME
local KeyFrame = Instance.new("Frame", gui)
KeyFrame.Size = UDim2.new(0,280,0,180)
KeyFrame.Position = UDim2.new(0.5,-140,0.5,-90)
KeyFrame.Active = true
KeyFrame.Draggable = true
styleFrame(KeyFrame)

local keyPad = Instance.new("UIPadding", KeyFrame)
keyPad.PaddingTop = UDim.new(0,10)
keyPad.PaddingLeft = UDim.new(0,10)
keyPad.PaddingRight = UDim.new(0,10)

local keyLayout = Instance.new("UIListLayout", KeyFrame)
keyLayout.Padding = UDim.new(0,10)

local KeyTitle = Instance.new("TextLabel", KeyFrame)
KeyTitle.Text = "Key System"
KeyTitle.Size = UDim2.new(1,0,0,30)
KeyTitle.BackgroundTransparency = 1
KeyTitle.TextScaled = true
KeyTitle.TextColor3 = Color3.new(1,1,1)

local KeyBox = makeBox("Enter Key")
KeyBox.Parent = KeyFrame

local Submit = makeButton("Unlock")
Submit.Parent = KeyFrame

--// LOGIC
local inf = false
local noclip = false
local opened = false

WSBtn.MouseButton1Click:Connect(function()
	local n = tonumber(WSBox.Text)
	if n and player.Character then
		player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = n
	end
end)

JPBtn.MouseButton1Click:Connect(function()
	local n = tonumber(JPBox.Text)
	if n and player.Character then
		player.Character:FindFirstChildOfClass("Humanoid").JumpPower = n
	end
end)

UIS.JumpRequest:Connect(function()
	if inf and player.Character then
		player.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
	end
end)

InfBtn.MouseButton1Click:Connect(function()
	inf = not inf
	InfBtn.Text = "Infinite Jump: "..(inf and "ON" or "OFF")
end)

RunService.Stepped:Connect(function()
	if noclip and player.Character then
		for _,v in pairs(player.Character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

NoclipBtn.MouseButton1Click:Connect(function()
	noclip = not noclip
	NoclipBtn.Text = "Noclip: "..(noclip and "ON" or "OFF")
end)

-- KEY
Submit.MouseButton1Click:Connect(function()
	if KeyBox.Text == KEY then
		KeyFrame.Visible = false
		Main.Visible = true
	else
		KeyBox.Text = "Wrong Key"
	end
end)

-- ANIMATION
local openPos = UDim2.new(1,-340,0.5,-150)
local closePos = UDim2.new(1,30,0.5,-150)

Toggle.MouseButton1Click:Connect(function()
	if not Main.Visible then return end
	opened = not opened
	
	local goal = opened and openPos or closePos
	local tween = TweenService:Create(Main, TweenInfo.new(0.35, Enum.EasingStyle.Quad), {Position = goal})
	tween:Play()

	if not opened then
		tween.Completed:Wait()
		Main.Visible = false
	end
end)
