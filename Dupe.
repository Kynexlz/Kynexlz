	local query = searchBox.Text:lower()
	for _, btn in pairs(toolButtons) do
		btn.Visible = btn.Text:lower():find(query) ~= nil
	end
end)

-- Quantity +/- 
minusBtn.MouseButton1Click:Connect(function()
	local num = tonumber(qtyBox.Text) or 1
	qtyBox.Text = math.max(1, num - 1)
end)

plusBtn.MouseButton1Click:Connect(function()
	local num = tonumber(qtyBox.Text) or 1
	qtyBox.Text = num + 1
end)

-- Duplicate Logic
dupeButton.MouseButton1Click:Connect(function()
	local qty = math.max(1, tonumber(qtyBox.Text) or 1)
	local selectedTool = nil
	
	for _, btn in pairs(toolButtons) do
		if btn.BackgroundColor3 == Color3.fromRGB(80, 140, 200) then
			selectedTool = btn:GetAttribute("SelectedTool")
			break
		end
	end
	
	if not selectedTool then return end
	
	local backpack = player:FindFirstChild("Backpack")
	if not backpack then return end
	
	for i = 1, qty do
		local clone = selectedTool:Clone()
		clone.Parent = backpack
	end
	
	-- Success animation + toast
	local origColor = dupeButton.BackgroundColor3
	dupeButton.BackgroundColor3 = Color3.fromRGB(0, 255, 140)
	TweenService:Create(dupeButton, TweenInfo.new(0.3), {BackgroundColor3 = origColor}):Play()
	
	-- Simple toast
	local toast = Instance.new("TextLabel")
	toast.Size = UDim2.new(0.6, 0, 0, 50)
	toast.Position = UDim2.new(0.2, 0, 0.8, 0)
	toast.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
	toast.Text = "Duplicated " .. qty .. "x " .. selectedTool.Name .. "!"
	toast.TextColor3 = Color3.new(1,1,1)
	toast.Font = Enum.Font.GothamBold
	toast.TextSize = 16
	toast.Parent = screenGui
	local tc = Instance.new("UICorner", toast)
	tc.CornerRadius = UDim.new(0, 10)
	
	TweenService:Create(toast, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0.2, 0, 0.9, 0), BackgroundTransparency = 1, TextTransparency = 1}):Play()
	game.Debris:AddItem(toast, 2.5)
end)

