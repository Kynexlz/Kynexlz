	warn.TextColor3 = Color3.fromRGB(255, 140, 140)
	warn.TextScaled = true
	warn.Font = Enum.Font.Gotham
	warn.Parent = mainFrame
end

-- Live Search
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	local q = searchBox.Text:lower()
	for _, btn in pairs(toolButtons) do
		btn.Visible = btn.Text:lower():find(q) ~= nil
	end
end)

-- Improved Dupe using Amount IntValue
dupeBtn.MouseButton1Click:Connect(function()
	local qty = tonumber(qtyBox.Text) or 10
	if qty < 1 then 
		qty = 10 
		qtyBox.Text = "10" 
	end

	local selectedTool = nil
	for _, btn in pairs(toolButtons) do
		if btn.BackgroundColor3 == Color3.fromRGB(80, 140, 200) then
			selectedTool = btn:GetAttribute("SelectedTool")
			break
		end
	end

	if not selectedTool then return end

	local backpack = player:FindFirstChild("Backpack")
	if not backpack then return end

	-- Clone the tool once
	local clone = selectedTool:Clone()

	-- Find or create Amount IntValue
	local amountValue = clone:FindFirstChild("Amount")
	if not amountValue then
		amountValue = Instance.new("IntValue")
		amountValue.Name = "Amount"
		amountValue.Parent = clone
	end

	-- Set the stack size (this is the key change)
	amountValue.Value = qty

	-- Parent to backpack
	clone.Parent = backpack

	-- Visual feedback
	local origColor = dupeBtn.BackgroundColor3
	dupeBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 120)
	task.wait(0.25)
	dupeBtn.BackgroundColor3 = origColor

	print("Duped " .. selectedTool.Name .. " with Amount = " .. qty)
end)

-- Draggable (works on mobile)
local dragging = false
local dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

mainFrame.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
		                               startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

