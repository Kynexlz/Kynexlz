-- Islands Persistent Dupe GUI v2 (April 2026) - More aggressive replication
-- Hold tool → INSERT to open

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local screenGui = Instance.new("ScreenGui")
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 360, 0, 280)
frame.Position = UDim2.new(0.5, -180, 0.5, -140)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0, 16); corner.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,50); title.BackgroundTransparency = 1
title.Text = "🌴 Islands REAL Persistent Dupe"
title.TextColor3 = Color3.fromRGB(0, 255, 140)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = frame

local heldLabel = Instance.new("TextLabel")
heldLabel.Size = UDim2.new(1,-20,0,30); heldLabel.Position = UDim2.new(0,10,0,60)
heldLabel.BackgroundTransparency = 1; heldLabel.Text = "Hold tool first"
heldLabel.TextColor3 = Color3.fromRGB(200,200,200); heldLabel.TextScaled = true
heldLabel.Parent = frame

local input = Instance.new("TextBox")
input.Size = UDim2.new(1,-20,0,45); input.Position = UDim2.new(0,10,0,100)
input.BackgroundColor3 = Color3.fromRGB(40,40,40); input.Text = "20"
input.TextColor3 = Color3.new(1,1,1); input.TextScaled = true; input.PlaceholderText = "Number of copies"
local ic = Instance.new("UICorner"); ic.CornerRadius = UDim.new(0,12); ic.Parent = input
input.Parent = frame

local btn = Instance.new("TextButton")
btn.Size = UDim2.new(1,-20,0,55); btn.Position = UDim2.new(0,10,0,155)
btn.BackgroundColor3 = Color3.fromRGB(0, 220, 100)
btn.Text = "DUPLICATE (Try to make persistent)"
btn.TextColor3 = Color3.new(1,1,1); btn.TextScaled = true; btn.Font = Enum.Font.GothamBold
local bc = Instance.new("UICorner"); bc.CornerRadius = UDim.new(0,12); bc.Parent = btn
btn.Parent = frame

local status = Instance.new("TextLabel")
status.Size = UDim2.new(1,-20,0,30); status.Position = UDim2.new(0,10,1,-40)
status.BackgroundTransparency = 1; status.Text = "Ready"
status.TextColor3 = Color3.fromRGB(100,255,100); status.TextScaled = true
status.Parent = frame

local close = Instance.new("TextButton")
close.Size = UDim2.new(0,40,0,40); close.Position = UDim2.new(1,-45,0,5)
close.BackgroundTransparency = 1; close.Text = "✕"; close.TextColor3 = Color3.fromRGB(255,80,80)
close.TextScaled = true; close.Parent = frame

local function getHeld() 
    local c = player.Character; if not c then return end
    for _,v in c:GetChildren() do if v:IsA("Tool") then return v end end
end

btn.MouseButton1Click:Connect(function()
    local tool = getHeld()
    if not tool then status.Text = "❌ Hold the tool!"; task.delay(2,function() status.Text="Ready" end) return end

    local amount = tonumber(input.Text) or 10
    status.Text = "Duplicating "..amount.." copies..."

    for i = 1, amount do
        local clone = tool:Clone()
        
        local amt = clone:FindFirstChild("Amount")
        if not amt then 
            amt = Instance.new("IntValue"); amt.Name = "Amount"; amt.Value = 1000000; amt.Parent = clone 
        else amt.Value = 1000000 end

        clone.Parent = player.Backpack
        task.wait(0.06)

        -- Extra server-push tricks
        pcall(function()
            clone.Parent = workspace
            task.wait(0.08)
            clone.Parent = player.Backpack
        end)

        if i % 3 == 0 then task.wait(0.3) end
    end

    status.Text = "✅ Duplication finished. Test placing one stack now."
    print("Persistent dupe attempt complete - check if any copies survive placing/rejoining")
end)

close.MouseButton1Click:Connect(function() screenGui:Destroy() end)

-- Toggle with INSERT
game:GetService("UserInputService").InputBegan:Connect(function(k,gp)
    if gp or k.KeyCode ~= Enum.KeyCode.Insert then return end
    frame.Visible = not frame.Visible
end)

task.spawn(function()
    while screenGui.Parent do
        local t = getHeld()
        heldLabel.Text = t and "Held: "..t.Name or "Hold a tool"
        task.wait(0.5)
    end
end)

print("Islands Persistent Dupe GUI v2 loaded - Press INSERT")
