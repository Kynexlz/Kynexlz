local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

local PREFIX = "/amount "
local lastValue = 0

local function getHeldTool()
    local char = player.Character
    if char then
        for _, obj in ipairs(char:GetChildren()) do
            if obj:IsA("Tool") then return obj end
        end
    end
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, obj in ipairs(backpack:GetChildren()) do
            if obj:IsA("Tool") then return obj end
        end
    end
    return nil
end

local function forceServerReplicate(tool, value)
    if not tool then return end
    lastValue = value

    -- Deep find Amount
    local amountValue = tool:FindFirstChild("Amount", true)
    if not amountValue or not amountValue:IsA("IntValue") then return end

    amountValue.Value = value

    -- MASS CLONE for real duplication (server often accepts clones)
    local clones = {}
    for i = 1, 5 do  -- create 5 clones
        local clone = tool:Clone()
        clone.Parent = player.Backpack
        local cloneAmount = clone:FindFirstChild("Amount", true)
        if cloneAmount then cloneAmount.Value = value end
        table.insert(clones, clone)
    end

    -- Server replication spam (this is the "server-sided" part)
    task.spawn(function()
        local originalParent = tool.Parent

        -- 1. Rapid parent swaps (triggers Roblox replication + server checks)
        for _ = 1, 8 do
            tool.Parent = nil
            task.wait(0.015)
            tool.Parent = originalParent or workspace
            task.wait(0.015)
        end

        -- 2. Clone parent spam
        for _, clone in ipairs(clones) do
            for _ = 1, 5 do
                clone.Parent = workspace
                task.wait(0.01)
                clone.Parent = player.Backpack
            end
        end
    end)

    -- 3. FIRE EVERY POSSIBLE REMOTE (this is what makes it feel server-sided)
    pcall(function()
        local folders = {ReplicatedStorage, ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage:FindFirstChild("Events") or ReplicatedStorage:FindFirstChild("Inventory")}
        for _, folder in ipairs(folders) do
            for _, remote in ipairs(folder:GetDescendants()) do
                if remote:IsA("RemoteEvent") then
                    local name = remote.Name:lower()
                    if name:find("drop") or name:find("place") or name:find("save") or name:find("tool") or name:find("inventory") or name:find("amount") or name:find("stack") then
                        -- Fire with manipulated amount (server often accepts this)
                        remote:FireServer(tool, value)
                        for _, clone in ipairs(clones) do
                            remote:FireServer(clone, value)
                        end
                    end
                end
            end
        end
    end)

    -- 4. Double lock (client + simulated server sync)
    local hbConn = RunService.Heartbeat:Connect(function()
        if amountValue and amountValue.Parent then amountValue.Value = value end
        for _, clone in ipairs(clones) do
            local cAmount = clone:FindFirstChild("Amount", true)
            if cAmount then cAmount.Value = value end
        end
    end)

    local rsConn = RunService.RenderStepped:Connect(function()
        if amountValue and amountValue.Parent then amountValue.Value = value end
    end)

    -- Keep alive for 15 seconds (long enough for drop/rejoin)
    task.delay(15, function()
        if hbConn then hbConn:Disconnect() end
        if rsConn then rsConn:Disconnect() end
    end)
end

player.Chatted:Connect(function(message)
    if not message:lower():sub(1, #PREFIX) == PREFIX:lower() then return end

    local valueStr = message:sub(#PREFIX + 1):match("^%s*(.-)%s*$")
    local value = tonumber(valueStr)
    if not value or value < 1 then return end

    local tool = getHeldTool()
    if not tool then return end

    forceServerReplicate(tool, value)

    -- Auto re-apply after any inventory change
    task.delay(0.3, function()
        local newTool = getHeldTool()
        if newTool then forceServerReplicate(newTool, value) end
    end)
end)

-- Super aggressive re-apply on character / island travel
player.CharacterAdded:Connect(function()
    task.wait(2)
    local tool = getHeldTool()
    if tool and lastValue > 0 then
        forceServerReplicate(tool, lastValue)
    end
end)

print("✅ Islands SERVER+CLIENT Dupe v4 loaded for DELTA")
print("   /amount <number> while holding tool")
print("   Drop/place the tool + its clones IMMEDIATELY then rejoin")
