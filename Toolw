-- Get held tool
local function getHeldTool()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return v
        end
    end
    return nil
end

-- Persistent duplication function
local function duplicateTool(count)
    local original = getHeldTool()
    if not original then
        status.Text = "❌ Equip the tool first!"
        status.TextColor3 = Color3.fromRGB(255, 80, 80)
        task.delay(2, function() status.Text = "Ready" end)
        return
    end

    toolLabel.Text = "Duplicating: " .. original.Name
    status.Text = "Duplicating " .. count .. " copies..."
    status.TextColor3 = Color3.fromRGB(255, 200, 0)

    print("Starting persistent dupe for " .. original.Name .. " x" .. count)

    for i = 1, count do
        local clone = original:Clone()
        
        -- Set high amount on each clone
        local amt = clone:FindFirstChild("Amount")
        if not amt or not amt:IsA("IntValue") then
            if amt then amt:Destroy() end
            amt = Instance.new("IntValue")
            amt.Name = "Amount"
            amt.Value = 1000000
            amt.Parent = clone
        else
            amt.Value = 1000000
        end

        -- Critical replication steps for Islands
        clone.Parent = player.Backpack
        task.wait(0.07)

        pcall(function()
            clone.Parent = player.Character
            task.wait(0.04)
            clone.Parent = player.Backpack
        end)

        if i % 4 == 0 then
            task.wait(0.25) -- small delay to avoid detection
        end
    end

    -- Final sync push
    pcall(function()
        player.Character.Humanoid:EquipTool(original)
        task.wait(0.2)
    end)

    status.Text = "✅ " .. count .. " copies created! (should persist after placing)"
    status.TextColor3 = Color3.fromRGB(0, 255, 120)
    print("Persistent dupe finished - check your hotbar/backpack")
end

