frame.Parent = gui

Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 14)

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(0, 170, 255)
stroke.Transparency = 0.5
stroke.Parent = frame

-- TITLE
local title = Instance.new("TextLabel")
