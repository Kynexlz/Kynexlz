Instance.new("UICorner", slot).CornerRadius = UDim.new(0, 12)

-- STACK TEXT
local stackText = Instance.new("TextLabel")
stackText.Size = UDim2.new(0, 180, 0, 40)
stackText.Position = UDim2.new(0, 90, 0, 65)
stackText.BackgroundTransparency = 1
stackText.TextColor3 = Color3.fromRGB(255, 255, 255)
stackText.Font = Enum.Font.GothamBold
stackText.TextSize = 16
stackText.TextXAlignment = Enum.TextXAlignment.Left
stackText.Text = "woodAxe x1"
stackText.Parent = frame

------------------------------------------------
-- DRAG SYSTEM
------------------------------------------------

local dragging = false
local dragStart
local startPos

frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then

		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)

frame.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if not dragging then return end

	if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch then

		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

------------------------------------------------
-- UPDATE UI
------------------------------------------------

local function updateUI()
	local tool = getTool()
	if not tool then
		stackText.Text = "No Tool"
		return
	end

	local stack = getStack(tool)
	if stack then
		stackText.Text = TOOL_NAME .. " x" .. stack.Value
	else
		stackText.Text = TOOL_NAME .. " x1"
	end
end

------------------------------------------------
-- ADD STACK
------------------------------------------------

local function addWoodAxe(amount)
	local tool = getTool()

	if not tool then
		ensureTool()
		task.wait(0.1)
		tool = getTool()
	end

	if tool then
		local stack = getStack(tool)
		stack.Value += amount
	end

	updateUI()
end

slot.MouseButton1Click:Connect(function()
	addWoodAxe(1)
end)

------------------------------------------------
-- KEY TOGGLE
------------------------------------------------

UIS.InputBegan:Connect(function(input, processed)
	if processed then return end

	if input.KeyCode == Enum.KeyCode.Z then
		frame.Visible = not frame.Visible
	end
end)

------------------------------------------------
-- INIT LOOP
------------------------------------------------

ensureTool()
updateUI()

while task.wait(0.2) do
	updateUI()
end
