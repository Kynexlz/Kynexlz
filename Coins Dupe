local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local backpack = player:WaitForChild("Backpack")

local TOOL_NAME = "woodAxe"

------------------------------------------------
-- TOOL HANDLING
------------------------------------------------

local function getTool()
	return backpack:FindFirstChild(TOOL_NAME)
		or (player.Character and player.Character:FindFirstChild(TOOL_NAME))
end

local function getStack(tool)
	if not tool then return nil end

	local stack = tool:FindFirstChild("Amount")
	if not stack then
		stack = Instance.new("IntValue") -- ✅ INT VALUE ONLY
		stack.Name = "Amount"
		stack.Value = 1
		stack.Parent = tool
	end

	return stack
end

local function ensureTool()
	local tool = getTool()

	if not tool then
		local starter = game:GetService("StarterPack"):FindFirstChild(TOOL_NAME)
		if starter then
			tool = starter:Clone()
			tool.Parent = backpack
		end
	end

	if tool and not tool:FindFirstChild("Amount") then
		local v = Instance.new("IntValue") -- ✅ INT VALUE
		v.Name = "Amount"
		v.Value = 1
		v.Parent = tool
	end
end

------------------------------------------------
-- GUI
------------------------------------------------

local gui = Instance.new("ScreenGui")
gui.Name = "InventoryUI"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- MAIN FRAME (CENTER SCREEN)
