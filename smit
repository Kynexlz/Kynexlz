-- Populate from ReplicatedStorage.Tools if exists
local toolsFolder = game.ReplicatedStorage:FindFirstChild("Tools")
local toolBtns = {}

if toolsFolder then
	for _, tool in pairs(toolsFolder:GetChildren()) do
		if tool:IsA("Tool") then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, 0, 0, 45)
			btn.BackgroundColor3 = Color3.fromRGB(45, 45, 52)
			btn.Text = "  " .. tool.Name
			btn.TextColor3 = Color3.new(1,1,1)
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.TextSize = 16
			btn.Font = Enum.Font.Gotham
			btn.Parent = scroll

			local btnc = Instance.new("UICorner")
			btnc.CornerRadius = UDim.new(0, 10)
			btnc.Parent = btn

			btn.MouseButton1Click:Connect(function()
				for _, b in pairs(toolBtns) do b.BackgroundColor3 = Color3.fromRGB(45,45,52) end
				btn.BackgroundColor3 = Color3.fromRGB(70, 130, 210)
			end)
			table.insert(toolBtns, btn)
		end
	end

	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 20)
	end)
end

-- Live search
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	local q = searchBox.Text:lower()
	for _, btn in pairs(toolBtns) do
		btn.Visible = btn.Text:lower():find(q) ~= nil
	end
end)

-- Main Action: Set Amount on held tool
actionBtn.MouseButton1Click:Connect(function()
	local amount = tonumber(amtBox.Text) or 1000000
	if amount < 1 then amount = 1000000 end

	local char = player.Character
	if not char then
		status.Text = "No character!"
		return
	end

	local held = char:FindFirstChildWhichIsA("Tool")
	if not held then
		status.Text = "Equip the tool first!"
		status.TextColor3 = Color3.fromRGB(255, 90, 90)
		return
	end

	local amtVal = held:FindFirstChild("Amount")
	if not amtVal then
		amtVal = Instance.new("IntValue")
		amtVal.Name = "Amount"
		amtVal.Parent = held
	end

	amtVal.Value = amount

	status.Text = "Amount set to " .. amount .. " on " .. held.Name .. "\nNow drop it manually!"
	status.TextColor3 = Color3.fromRGB(0, 255, 140)

	-- Button flash
	local orig = actionBtn.BackgroundColor3
	actionBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 160)
	task.wait(0.25)
	actionBtn.BackgroundColor3 = orig
end)

-- Auto status update
local function updateStatus()
	local char = player.Character
	if char then
		local tool = char:FindFirstChildWhichIsA("Tool")
		if tool then
			status.Text = "Held: " .. tool.Name .. "\nReady to set amount and drop"
			status.TextColor3 = Color3.fromRGB(255, 255, 255)
		else
			status.Text = "Equip the tool you want to dupe"
			status.TextColor3 = Color3.fromRGB(200, 200, 210)
		end
	end
end

if player.Character then updateStatus() end
player.CharacterAdded:Connect(function() task.wait(1); updateStatus() end)
player.Character.ChildAdded:Connect(updateStatus)
player.Character.ChildRemoved:Connect(updateStatus)

-- Draggable
local dragging = false
local dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

mainFrame.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

