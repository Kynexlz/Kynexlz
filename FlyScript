--// SETTINGS
local KEY = "Kynexlz"
local ANIMATION_ID = "rbxassetid://113298527970213"

--// SERVICES
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local humanoid = char:WaitForChild("Humanoid")

--// VARIABLES
local flying = false
local speed = 50
local bv, bg
local keys = {W=false,A=false,S=false,D=false}

--// GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "FlyGui"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 260, 0, 180)
frame.Position = UDim2.new(0.5, -130, 0.5, -90)
frame.BackgroundColor3 = Color3.fromRGB(15,15,15)
frame.Active = true
frame.Draggable = true

Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Fly System"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.TextScaled = true

local keyBox = Instance.new("TextBox", frame)
keyBox.PlaceholderText = "Enter Key"
keyBox.Size = UDim2.new(0.8,0,0,30)
keyBox.Position = UDim2.new(0.1,0,0.25,0)
keyBox.BackgroundColor3 = Color3.fromRGB(25,25,25)
keyBox.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", keyBox)

local submit = Instance.new("TextButton", frame)
submit.Text = "Unlock"
submit.Size = UDim2.new(0.8,0,0,30)
submit.Position = UDim2.new(0.1,0,0.45,0)
submit.BackgroundColor3 = Color3.fromRGB(40,40,40)
submit.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", submit)

local speedBox = Instance.new("TextBox", frame)
speedBox.PlaceholderText = "Fly Speed"
speedBox.Size = UDim2.new(0.8,0,0,30)
speedBox.Position = UDim2.new(0.1,0,0.65,0)
speedBox.BackgroundColor3 = Color3.fromRGB(25,25,25)
speedBox.TextColor3 = Color3.new(1,1,1)
speedBox.Visible = false
Instance.new("UICorner", speedBox)

local toggle = Instance.new("TextButton", frame)
toggle.Text = "Fly: OFF"
toggle.Size = UDim2.new(0.8,0,0,30)
toggle.Position = UDim2.new(0.1,0,0.82,0)
toggle.BackgroundColor3 = Color3.fromRGB(40,40,40)
toggle.TextColor3 = Color3.new(1,1,1)
toggle.Visible = false
Instance.new("UICorner", toggle)

--// ANIMATION
local anim = Instance.new("Animation")
anim.AnimationId = ANIMATION_ID
local track

--// KEY SYSTEM
submit.MouseButton1Click:Connect(function()
	if keyBox.Text == KEY then
		keyBox.Visible = false
		submit.Visible = false
		speedBox.Visible = true
		toggle.Visible = true
	end
end)

--// SPEED INPUT
speedBox.FocusLost:Connect(function()
	local val = tonumber(speedBox.Text)
	if val then
		speed = val
	end
end)

--// FLY FUNCTION
local function startFly()
	flying = true
	
	bv = Instance.new("BodyVelocity", hrp)
	bv.MaxForce = Vector3.new(9e9,9e9,9e9)
	bv.Velocity = Vector3.zero
	
	bg = Instance.new("BodyGyro", hrp)
	bg.MaxTorque = Vector3.new(9e9,9e9,9e9)
	bg.CFrame = hrp.CFrame
	
	track = humanoid:LoadAnimation(anim)
	track:Play()
end

local function stopFly()
	flying = false
	
	if bv then bv:Destroy() end
	if bg then bg:Destroy() end
	
	if track then track:Stop() end
end

--// TOGGLE
toggle.MouseButton1Click:Connect(function()
	if flying then
		stopFly()
		toggle.Text = "Fly: OFF"
	else
		startFly()
		toggle.Text = "Fly: ON"
	end
end)

--// CONTROLS (PC + MOBILE SUPPORT)
UIS.InputBegan:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.W then keys.W = true end
	if input.KeyCode == Enum.KeyCode.S then keys.S = true end
	if input.KeyCode == Enum.KeyCode.A then keys.A = true end
	if input.KeyCode == Enum.KeyCode.D then keys.D = true end
end)

UIS.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.W then keys.W = false end
	if input.KeyCode == Enum.KeyCode.S then keys.S = false end
	if input.KeyCode == Enum.KeyCode.A then keys.A = false end
	if input.KeyCode == Enum.KeyCode.D then keys.D = false end
end)

--// FLY LOOP
RunService.RenderStepped:Connect(function()
	if flying and bv and bg then
		local cam = workspace.CurrentCamera
		local dir = Vector3.zero
		
		if keys.W then dir += cam.CFrame.LookVector end
		if keys.S then dir -= cam.CFrame.LookVector end
		if keys.A then dir -= cam.CFrame.RightVector end
		if keys.D then dir += cam.CFrame.RightVector end
		
		bv.Velocity = dir * speed
		bg.CFrame = cam.CFrame
	end
end)
